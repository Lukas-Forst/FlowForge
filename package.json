{
  "name": "flowforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild": "node ./scripts/assets/size-check.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "perf:guard": "node ./scripts/perf/guard.mjs",
    "assets:size-check": "node ./scripts/assets/size-check.mjs",
    "assets:optimize": "node ./scripts/assets/optimize.mjs",
    "assets:props:generate": "node ./scripts/meshy/generate-props.mjs",
    "assets:props:plan": "node ./scripts/meshy/generate-props.mjs --dry-run",
    "assets:structures:generate": "node ./scripts/meshy/generate-structures.mjs",
    "assets:structures:plan": "node ./scripts/meshy/generate-structures.mjs --dry-run"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "partysocket": "^1.1.18",
    "postprocessing": "^6.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.2.1",
    "@gltf-transform/core": "^4.2.1",
    "@gltf-transform/extensions": "^4.2.1",
    "@gltf-transform/functions": "^4.2.1",
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "draco3dgltf": "^1.5.7",
    "meshoptimizer": "^0.25.0",
    "sharp": "^0.34.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.4"
  }
}
